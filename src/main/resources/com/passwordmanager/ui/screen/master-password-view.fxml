<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.Region?>
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.passwordmanager.ui.screen.MasterPasswordController"
           style="-fx-background-color: transparent; -fx-padding: 20;">

    <VBox fx:id="rootPane"
          spacing="20"
          prefWidth="460"
          style="-fx-padding: 40 36 36 36;
                 -fx-background-color: #0f141d;
                 -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.65), 28, 0.3, 0, 6);">

        <VBox spacing="4">
            <Label text="Password Manager" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #f5f7fa;"/>
            <Label fx:id="subtitleLabel" style="-fx-text-fill: #a8b3c2; -fx-font-size: 13px;"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Master password" style="-fx-text-fill: #a8b3c2; -fx-font-size: 12px;"/>
            <PasswordField fx:id="passwordField" promptText="Enter password…" styleClass="password-field"/>
        </VBox>

        <VBox fx:id="confirmRow" spacing="6">
            <Label text="Confirm password" style="-fx-text-fill: #a8b3c2; -fx-font-size: 12px;"/>
            <PasswordField fx:id="confirmField" promptText="Confirm password…" styleClass="password-field"/>
        </VBox>

        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #ff5d73; -fx-font-size: 12px;"/>

        <Region prefHeight="4"/>

        <Button fx:id="submitButton"
                onAction="#handleSubmit"
                styleClass="primary-button"
                maxWidth="Infinity"/>

    </VBox>
</StackPane>
