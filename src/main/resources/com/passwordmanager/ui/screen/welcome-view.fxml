<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.passwordmanager.ui.screen.WelcomeController"
           style="-fx-background-color: transparent; -fx-padding: 24;">

    <VBox fx:id="rootPane"
          spacing="28"
          prefWidth="580"
          style="-fx-padding: 48 44 44 44;
                 -fx-background-color: #0f141d;
                 -fx-background-radius: 20;
                 -fx-border-color: rgba(255,255,255,0.07);
                 -fx-border-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.70), 36, 0.3, 0, 10);">

        <!-- Header -->
        <VBox spacing="8" style="-fx-alignment: center;">
            <Label text="Password Manager" styleClass="app-title"
                   style="-fx-font-size: 30px; -fx-font-weight: 800;"/>
            <Label text="Local-first, encrypted credential vault"
                   styleClass="subtitle"
                   style="-fx-font-size: 15px;"/>
            <Label text="No servers. No cloud sync. Your data, your rules."
                   style="-fx-text-fill: #5b8cff; -fx-font-size: 13px; -fx-font-weight: 600;"/>
        </VBox>

        <Separator style="-fx-opacity: 0.12;"/>

        <!-- Feature Cards -->
        <VBox spacing="12">

            <HBox spacing="20" styleClass="elevated-card" alignment="CENTER_LEFT">
                <Label text="⊙"
                       style="-fx-background-color: rgba(91,140,255,0.16);
                              -fx-background-radius: 14;
                              -fx-border-color: rgba(91,140,255,0.28);
                              -fx-border-radius: 14;
                              -fx-text-fill: #5b8cff;
                              -fx-font-size: 26px;
                              -fx-min-width: 54; -fx-min-height: 54;
                              -fx-max-width: 54; -fx-max-height: 54;
                              -fx-alignment: center;"/>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Fully Local and Private"
                           style="-fx-text-fill: #f5f7fa; -fx-font-size: 15px; -fx-font-weight: 700;"/>
                    <Label text="Your credentials are encrypted with AES-256-GCM and stored only on this device. Nothing is ever sent to any server."
                           styleClass="subtitle"
                           wrapText="true"/>
                </VBox>
            </HBox>

            <HBox spacing="20" styleClass="elevated-card" alignment="CENTER_LEFT">
                <Label text="⊕"
                       style="-fx-background-color: rgba(53,196,106,0.16);
                              -fx-background-radius: 14;
                              -fx-border-color: rgba(53,196,106,0.28);
                              -fx-border-radius: 14;
                              -fx-text-fill: #35c46a;
                              -fx-font-size: 26px;
                              -fx-min-width: 54; -fx-min-height: 54;
                              -fx-max-width: 54; -fx-max-height: 54;
                              -fx-alignment: center;"/>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Backup Your Way"
                           style="-fx-text-fill: #f5f7fa; -fx-font-size: 15px; -fx-font-weight: 700;"/>
                    <Label text="Use Export to copy your encrypted vault to a Google Drive, Dropbox, or USB sync folder. The file stays encrypted — safe even in the cloud."
                           styleClass="subtitle"
                           wrapText="true"/>
                </VBox>
            </HBox>

            <HBox spacing="20" styleClass="elevated-card" alignment="CENTER_LEFT">
                <Label text="⊖"
                       style="-fx-background-color: rgba(242,185,75,0.16);
                              -fx-background-radius: 14;
                              -fx-border-color: rgba(242,185,75,0.28);
                              -fx-border-radius: 14;
                              -fx-text-fill: #f2b94b;
                              -fx-font-size: 26px;
                              -fx-min-width: 54; -fx-min-height: 54;
                              -fx-max-width: 54; -fx-max-height: 54;
                              -fx-alignment: center;"/>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Restore from Backup"
                           style="-fx-text-fill: #f5f7fa; -fx-font-size: 15px; -fx-font-weight: 700;"/>
                    <Label text="Already have a vault file from another device? Import it to restore your credentials. You will need the master password used when the vault was created."
                           styleClass="subtitle"
                           wrapText="true"/>
                </VBox>
            </HBox>

        </VBox>

        <Label fx:id="errorLabel" text=""
               styleClass="danger-text"
               style="-fx-font-size: 12px;"/>

        <!-- Buttons -->
        <VBox spacing="10">
            <Button text="Create New Vault"
                    styleClass="primary-button"
                    maxWidth="Infinity"
                    style="-fx-font-size: 15px; -fx-padding: 14 20 14 20;"
                    onAction="#onCreateVault"/>
            <Button text="Import Existing Vault"
                    styleClass="ghost-button"
                    maxWidth="Infinity"
                    style="-fx-font-size: 14px; -fx-padding: 12 20 12 20;"
                    onAction="#onImport"/>
        </VBox>

    </VBox>
</StackPane>
