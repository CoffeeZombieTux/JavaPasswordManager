<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<VBox fx:id="detailPane"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.passwordmanager.ui.component.detail.CredentialDetailController"
      styleClass="details-panel">
    <Label fx:id="name" styleClass="detail-header-title"/>

    <GridPane fx:id="fieldsGrid" hgap="16" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="110" prefWidth="110"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Username:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
        <Label fx:id="username" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Password:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
        <Label fx:id="password" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Website:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
        <Label fx:id="website" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Category:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.valignment="CENTER"/>
        <Label fx:id="category" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Notes:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.valignment="TOP"/>
        <Text fx:id="notes" styleClass="notes-text" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Created At:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.valignment="CENTER"/>
        <Label fx:id="createdAt" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="Updated At:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="6" GridPane.valignment="CENTER"/>
        <Label fx:id="updatedAt" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
    </GridPane>

    <GridPane hgap="12" vgap="12" styleClass="detail-buttons-grid" nodeOrientation="LEFT_TO_RIGHT">
        <padding>
            <Insets top="25.0" right="25.0" bottom="25.0" left="0.0"/>
        </padding>
        <Button fx:id="showPasswordButton" text="Show Password" styleClass="action-button" GridPane.columnIndex="0" GridPane.rowIndex="0" onAction="#handleShowPassword" />
        <Button text="Copy Password" styleClass="action-button" GridPane.columnIndex="1" GridPane.rowIndex="0" onAction="#handleCopyPassword" />
        <Button text="Edit" styleClass="action-button" GridPane.columnIndex="0" GridPane.rowIndex="1" onAction="#handleEditCredential" />
        <Button text="Delete" styleClass="action-button" GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#handleDeleteCredential" />
    </GridPane>
</VBox>
