<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<VBox fx:id="detailPane"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.passwordmanager.ui.component.detail.CredentialDetailController"
      styleClass="details-panel">
    <Label fx:id="name" styleClass="detail-header-title"/>

    <VBox spacing="10">
        <HBox fx:id="websiteRow" spacing="16" alignment="CENTER_LEFT">
            <Label text="Website:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <Label fx:id="website" styleClass="detail-value" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox fx:id="usernameRow" spacing="16" alignment="CENTER_LEFT">
            <Label text="Username:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <Label fx:id="username" styleClass="detail-value" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox fx:id="passwordRow" spacing="16" alignment="CENTER_LEFT">
            <Label text="Password:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <Label fx:id="password" styleClass="detail-value" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox fx:id="categoryRow" spacing="16" alignment="CENTER_LEFT">
            <Label text="Category:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <Label fx:id="category" styleClass="detail-value" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox fx:id="notesRow" spacing="16" alignment="TOP_LEFT">
            <Label text="Notes:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <Text fx:id="notes" styleClass="notes-text"/>
        </HBox>
        <HBox fx:id="createdAtRow" spacing="16" alignment="CENTER_LEFT">
            <Label text="Created At:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <Label fx:id="createdAt" styleClass="detail-value" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox fx:id="updatedAtRow" spacing="16" alignment="CENTER_LEFT">
            <Label text="Updated At:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <Label fx:id="updatedAt" styleClass="detail-value" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <GridPane hgap="12" vgap="12" styleClass="detail-buttons-grid" nodeOrientation="LEFT_TO_RIGHT">
        <padding>
            <Insets top="25.0" right="25.0" bottom="25.0" left="0.0"/>
        </padding>
        <Button fx:id="showPasswordButton" text="Show Password" styleClass="action-button" GridPane.columnIndex="0" GridPane.rowIndex="0" onAction="#handleShowPassword" />
        <Button fx:id="copyPasswordButton" text="Copy Password" styleClass="action-button" GridPane.columnIndex="1" GridPane.rowIndex="0" onAction="#handleCopyPassword" />
        <Button text="Edit" styleClass="action-button" GridPane.columnIndex="0" GridPane.rowIndex="1" onAction="#handleEditCredential" />
        <Button text="Delete" styleClass="action-button" GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#handleDeleteCredential" />
    </GridPane>
</VBox>
