<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<VBox fx:id="addFormPane"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.passwordmanager.ui.component.form.AddCredentialFormController"
      styleClass="form-panel">
    <Label fx:id="title" styleClass="detail-header-title"/>

    <GridPane hgap="16" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="110" prefWidth="110"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Name:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.valignment="CENTER"/>
        <TextField fx:id="name" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity" GridPane.hgrow="ALWAYS"/>

        <Label text="Username:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.valignment="CENTER"/>
        <TextField fx:id="username" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity" GridPane.hgrow="ALWAYS"/>

        <Label text="Password:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.valignment="CENTER"/>
        <TextField fx:id="password" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity" GridPane.hgrow="ALWAYS"/>

        <Label text="Website:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.valignment="CENTER"/>
        <TextField fx:id="website" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="Infinity" GridPane.hgrow="ALWAYS"/>

        <Label text="Category:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.valignment="CENTER"/>
        <TextField fx:id="category" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="4" maxWidth="Infinity" GridPane.hgrow="ALWAYS"/>

        <Label text="Notes:" styleClass="detail-label" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.valignment="TOP"/>
        <TextArea fx:id="notes" styleClass="detail-value" GridPane.columnIndex="1" GridPane.rowIndex="5" maxWidth="Infinity" GridPane.hgrow="ALWAYS" prefRowCount="4" wrapText="true"/>
    </GridPane>

    <GridPane hgap="12" vgap="12" styleClass="detail-buttons-grid" nodeOrientation="LEFT_TO_RIGHT">
        <padding>
            <Insets top="25.0" right="25.0" bottom="25.0" left="0.0"/>
        </padding>
        <Button text="Save" styleClass="action-button" GridPane.columnIndex="0" GridPane.rowIndex="1" onAction="#handleSaveCredential" />
        <Button text="Cancel" styleClass="action-button" GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#handleCancelEditing" />
    </GridPane>
</VBox>
