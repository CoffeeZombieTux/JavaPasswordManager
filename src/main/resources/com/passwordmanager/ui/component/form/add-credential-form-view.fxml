<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<VBox fx:id="addFormPane"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.passwordmanager.ui.component.form.AddCredentialFormController"
      styleClass="form-panel">
    <Label fx:id="title" styleClass="detail-header-title"/>
    <HBox fx:id="typeGroupContainer" styleClass="type-tab-bar">
        <fx:define>
            <ToggleGroup fx:id="typeGroup"/>
        </fx:define>
        <ToggleButton text="Account" styleClass="type-tab" toggleGroup="$typeGroup" userData="ACCOUNT" selected="true"/>
        <ToggleButton text="Token" styleClass="type-tab" toggleGroup="$typeGroup" userData="TOKEN"/>
        <ToggleButton text="Note" styleClass="type-tab" toggleGroup="$typeGroup" userData="NOTE"/>
    </HBox>

    <VBox spacing="10">
        <HBox fx:id="nameRow" spacing="16" alignment="CENTER_LEFT">
            <Label text="Name:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <TextField fx:id="name" styleClass="detail-value" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox fx:id="usernameRow" spacing="16" alignment="CENTER_LEFT">
            <Label text="Username:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <TextField fx:id="username" styleClass="detail-value" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox fx:id="passwordRow" spacing="16" alignment="CENTER_LEFT">
            <Label fx:id="passwordRowLabel" text="Password:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <PasswordField fx:id="password" styleClass="detail-value" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <TextField fx:id="passwordPlain" styleClass="detail-value" maxWidth="Infinity" HBox.hgrow="ALWAYS" visible="false" managed="false"/>
            <Button fx:id="showPasswordButton" text="Show" styleClass="action-button" onAction="#handleShowPassword"/>
        </HBox>
        <HBox fx:id="websiteRow" spacing="16" alignment="CENTER_LEFT">
            <Label text="Website:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <TextField fx:id="website" styleClass="detail-value" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox fx:id="categoryRow" spacing="16" alignment="CENTER_LEFT">
            <Label text="Category:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <TextField fx:id="category" styleClass="detail-value" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox fx:id="notesRow" spacing="16" alignment="TOP_LEFT">
            <Label text="Notes:" styleClass="detail-label" minWidth="110" prefWidth="110"/>
            <TextArea fx:id="notes" styleClass="detail-value" maxWidth="Infinity" HBox.hgrow="ALWAYS" prefRowCount="4" wrapText="true"/>
        </HBox>
    </VBox>

    <GridPane hgap="12" vgap="12" styleClass="detail-buttons-grid" nodeOrientation="LEFT_TO_RIGHT">
        <padding>
            <Insets top="25.0" right="25.0" bottom="25.0" left="0.0"/>
        </padding>
        <Button text="Save" styleClass="action-button" GridPane.columnIndex="0" GridPane.rowIndex="1" onAction="#handleSaveCredential" />
        <Button text="Cancel" styleClass="action-button" GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#handleCancelEditing" />
    </GridPane>
</VBox>
