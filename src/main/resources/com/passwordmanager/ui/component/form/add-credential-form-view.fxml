<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.GridPane?>
<VBox fx:id="addFormPane"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.passwordmanager.ui.component.form.AddCredentialFormController"
      styleClass="form-panel">
    <Label fx:id="title" styleClass="detail-header-title"/>
    <HBox>
        <Label text="Name: " styleClass="detail-label"/>
        <TextField fx:id="name" styleClass="detail-value"/>
    </HBox>
    <HBox>
        <Label text="Username: " styleClass="detail-label"/>
        <TextField fx:id="username" styleClass="detail-value"/>
    </HBox>
    <HBox>
        <Label text="Password: " styleClass="detail-label"/>
        <TextField fx:id="password" styleClass="detail-value"/>
    </HBox>
    <HBox>
        <Label text="Website: " styleClass="detail-label"/>
        <TextField fx:id="website" styleClass="detail-value"/>
    </HBox>
    <HBox>
        <Label text="Category: " styleClass="detail-label"/>
        <TextField fx:id="category" styleClass="detail-value"/>
    </HBox>
    <VBox>
        <Label text="Notes: " styleClass="detail-label"/>
        <TextField fx:id="notes" styleClass="detail-value"/>
    </VBox>

    <GridPane hgap="12" vgap="12" styleClass="detail-buttons-grid" nodeOrientation="LEFT_TO_RIGHT">
        <padding>
            <Insets top="25.0" right="25.0" bottom="25.0" left="0.0"/>
        </padding>
        <Button text="Save" styleClass="action-button" GridPane.columnIndex="0" GridPane.rowIndex="1" onAction="#handleSaveCredential" />
        <Button text="Cancel" styleClass="action-button" GridPane.columnIndex="1" GridPane.rowIndex="1" onAction="#handleCancelEditing" />

    </GridPane>
</VBox>