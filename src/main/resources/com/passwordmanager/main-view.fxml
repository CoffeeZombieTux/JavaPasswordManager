<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.StackPane?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.passwordmanager.ui.MainController"
            styleClass="main-surface">
    <top>
        <HBox styleClass="topbar">
            <Label text="Password Manager" styleClass="app-title"/>
            <TextField promptText="Search passwords..." styleClass="search-field"/>
            <Button text="+ Add" styleClass="primary-button"/>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar">
            <Button text="All Passwords" styleClass="nav-button active"/>
            <Button text="Favorites" styleClass="nav-button"/>
            <Button text="Security Checkup" styleClass="nav-button"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="center-panel">
            <HBox spacing="12">
                <VBox styleClass="stat-card">
                    <Label fx:id="totalCountLabel" text="0" styleClass="stat-value"/>
                    <Label text="Total Passwords" styleClass="stat-label"/>
                </VBox>
            </HBox>
            <ListView fx:id="credentialListView" />
        </VBox>
    </center>

    <right>
        <StackPane minWidth="600.0">
            <VBox fx:id="detailPane" styleClass="details-panel">
                <Label fx:id="selectedTitleLabel" text="Select a credential" styleClass="detail-header-title"/>
                <Label fx:id="selectedUsernameLabel" text="" styleClass="stat-label"/>
            </VBox>

            <VBox fx:id="addFormPane" styleClass="form-panel">
                <Label text="Add credential" styleClass="detail-header-title" />
                <TextField fx:id="newTitleField" promptText="Title" />
                <TextField fx:id="newUsernameField" promptText="Username" />
                <TextField fx:id="newWebsiteField" promptText="Website" />
                <Button text="Save" onAction="#handleSaveCredential" />
            </VBox>
        </StackPane>
    </right>
</BorderPane>
